      "targets": [
        {
          "expr": "sum by(service) (rate({namespace=\"$namespace\", service=~\"url-service|redirect-service|analytics-service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
